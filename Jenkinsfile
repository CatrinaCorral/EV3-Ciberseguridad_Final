pipeline {
    agent any

    stages {
        stage('Construcción') {
            steps {
                echo 'Construyendo la aplicación...'
            }
        }

        stage('Pruebas') {
            steps {
                echo 'Ejecutando pruebas básicas...'
            }
        }

        stage('Despliegue') {
            steps {
                echo 'Desplegando la aplicación en entorno de prueba...'
            }
        }
    }
}
